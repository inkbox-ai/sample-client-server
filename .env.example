# .env.example
#
# Local:  cp .env.example .env && chmod 600 .env   (loaded via python-dotenv)
# Docker: skip the file and pass the same variables with `docker run -e KEY=VAL`

# Inkbox API key (from console.inkbox.ai). Required to list and patch
# phone numbers + mailboxes on boot, and to drive the tunnels control plane.
INKBOX_API_KEY=

# OpenAI API key used by the sample phone agent to generate live call replies.
OPENAI_API_KEY=

# --- Signing ------------------------------------------------------------------

# Your Inkbox webhook signing secret (from the Inkbox dashboard).
# Required when INKBOX_REQUIRE_SIGNATURE=true (the default).
# Go to https://inkbox.ai/console/webhooks to create a signing key.
INKBOX_SIGNING_KEY=

# When true (default), /webhook and the phone media WebSocket both reject
# requests without a valid X-Inkbox-Signature. Set to "false" for local
# testing only.
INKBOX_REQUIRE_SIGNATURE=true

# --- Server -------------------------------------------------------------------

LISTEN_PORT=8080

# --- Inkbox tunnel ------------------------------------------------------------

# Customer-chosen subdomain (no dots, lowercase, hyphens OK).
INKBOX_TUNNEL_NAME=

# `edge` or `passthrough`. Default: edge (Inkbox terminates TLS for you).
# `passthrough` makes this process the TLS terminator using a per-tunnel
# Let's Encrypt cert; the private key never leaves your machine.
INKBOX_TUNNEL_TLS_MODE=edge

# Leave blank on first run — bootstrap creates the tunnel and persists
# the secret under INKBOX_TUNNEL_STATE_DIR.
INKBOX_TUNNEL_SECRET=

# Pinned to development. Override only if you know what you're doing.
INKBOX_API_BASE=https://development.inkbox.ai/api/v1
INKBOX_TUNNEL_ZONE=development.inkboxwire.com

# Optional. Defaults: pool=32, state-dir=./.inkbox-tunnel-state.
INKBOX_TUNNEL_POOL_SIZE=32
INKBOX_TUNNEL_STATE_DIR=./.inkbox-tunnel-state

# --- Phone media WebSocket opt-in ---------------------------------------------

# On the /phone/media/ws handshake response, the server echoes these headers
# to opt into Inkbox-managed TTS / STT for the call. Set either to "false" if
# your client synthesizes audio or transcribes caller audio itself.
X_USE_INKBOX_TEXT_TO_SPEECH=true
X_USE_INKBOX_SPEECH_TO_TEXT=true
