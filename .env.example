# .env.example

# Inkbox Webhook Configuration
# Local:  cp .env.example .env && chmod 600 .env  (loaded via python-dotenv)
# Docker: skip the file and pass the same variables with `docker run -e KEY=VAL`

# Signing key from POST /signing-keys (plaintext, shown only once)
INKBOX_SIGNING_KEY=whsec_your-signing-key-here

# Inkbox API key — unused by the server today, but wire it in if you extend
# this repo with `inkbox` SDK client code (send email, place call, etc.)
INKBOX_API_KEY=ApiKey_your-api-key-here

# Server
LISTEN_PORT=8080

# Path prefix when mounted behind a CDN with path-based routing (e.g. /my-agent)
PATH_PREFIX=

# Phone webhook behavior
# If true, incoming_call webhooks respond with {"action":"answer"} (default true)
INKBOX_PHONE_AUTO_ANSWER=true
# WebSocket URL Inkbox should connect to for live call media. Example:
# wss://bots.development.inkbox.ai/alex/phone/media/ws
INKBOX_PHONE_CLIENT_WEBSOCKET_URL=

# Local media stream server bind/port (inkbox-phone-media entrypoint)
INKBOX_PHONE_MEDIA_HOST=0.0.0.0
INKBOX_PHONE_MEDIA_PORT=8090
